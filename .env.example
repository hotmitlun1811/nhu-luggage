# Gmail SMTP — powers the automated "policy & agreement" email sent from the
# booking forms. Copy this file to .env.local for local dev, and add the same
# keys to the Vercel project's Environment Variables for production.

# The Gmail account that authenticates and actually sends the mail. Must have
# 2-Step Verification on, with an App Password generated for "Mail" at
# https://myaccount.google.com/apppasswords — a normal account password will
# not work. Gmail's relay requires the "from" address to match this account,
# so this is also who the customer sees as the sender.
GMAIL_USER=

# The 16-character App Password (spaces optional, either form works).
GMAIL_APP_PASSWORD=

# Where customer replies should land — doesn't have to match GMAIL_USER.
EMAIL_REPLY_TO=stowdanang@gmail.com

# Public site URL, used to build absolute links (Terms/Privacy) inside the email.
NEXT_PUBLIC_SITE_URL=https://nhu-luggage.vercel.app
